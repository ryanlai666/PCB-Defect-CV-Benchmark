# ─── External Model Repos (tracked separately, not committed here) ────────────
# DEIMv2 and DINOv3 are cloned/placed manually — see README.md
DEIMv2/
dinov3/

# ─── Datasets ─────────────────────────────────────────────────────────────────
Bridge_Crack_Image/
CrackForest/
DeepPCB/
Magnetic-Tile-Defect/
archive.zip

# Converted COCO dataset cache (regeneratable via scripts/convert_deeppcb_to_coco.py)
data/deeppcb_coco/

# ─── Model Checkpoints & Weights ──────────────────────────────────────────────
# Individual pretrained weights / best-model files
*.pth
*.pt
*.engine
*.onnx

# DEIMv2 checkpoint symlink dir
DEIMv2/ckpts/

# ─── Outputs, Logs, and Runs ──────────────────────────────────────────────────
logs/
outputs/
runs/
results/
*.log

# Backup snapshots of training runs (for comparison)
outputs_*_backup/
logs_*_backup/
results_*_backup/

# DEIMv2 own output dir (generated inside DEIMv2/)
DEIMv2/outputs/

# ─── Python Cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ─── Jupyter Notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Virtual Environments ─────────────────────────────────────────────────────
venv/
env/
.env

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
